# ── Application ──────────────────────────────────────────────────────────
APP_NAME=StockEx
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_BASE_URL=http://localhost:8000

# ── MongoDB ──────────────────────────────────────────────────────────────
MONGODB_URL=mongodb://localhost:27017/nexbrokers
MONGODB_DB_NAME=nexbrokers
MONGODB_REPLICA_SET=
MONGODB_MAX_POOL_SIZE=100
MONGODB_MIN_POOL_SIZE=10

# ── Risk-loop sharding ─────────────────────────────────────────────────────
# How many shards the risk_enforcer (SL/TP/stop-out) is split across.
# 1 (DEFAULT) = single-worker on leader:feed, in-process prices = today's
# behaviour. Raise to >1 (and <= worker count) ONLY when
# `risk_enforcer_tick_overrun` is sustained > 1-2s, and ONLY off-market.
RISK_SHARDS=1

# ── Redis ────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=50

# ── JWT ──────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string_in_production_at_least_64_chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=7

# ── Admin extra security ─────────────────────────────────────────────────
ADMIN_API_KEY=change_this_admin_api_key_use_a_long_random_string
ADMIN_IP_WHITELIST=

# ── CORS ─────────────────────────────────────────────────────────────────
CORS_USER_ORIGIN=http://localhost:3000
CORS_ADMIN_ORIGIN=http://localhost:3001

# ── Rate limiting (per-minute) ───────────────────────────────────────────
RATE_LIMIT_AUTH_PER_MIN=5
RATE_LIMIT_DEFAULT_PER_MIN=100
RATE_LIMIT_TRADING_PER_MIN=300

# ── External market data ─────────────────────────────────────────────────
ANGEL_ONE_API_KEY=
ANGEL_ONE_CLIENT_CODE=
ANGEL_ONE_CLIENT_PIN=
ANGEL_ONE_TOTP_SECRET=
ZERODHA_API_KEY=
ZERODHA_API_SECRET=
PRICE_FEED_PROVIDER=mock

# ── Infoway (forex + crypto + metals + energy) ──────────────────────────
# Get a token from https://infoway.io
INFOWAY_API_KEY=
INFOWAY_AUTO_CONNECT=true
INFOWAY_DEFAULT_CRYPTO=BTCUSDT,ETHUSDT,SOLUSDT,XRPUSDT,DOGEUSDT,BNBUSDT,ADAUSDT,MATICUSDT
INFOWAY_DEFAULT_FOREX=EURUSD,GBPUSD,USDJPY,AUDUSD,USDCAD,USDCHF,NZDUSD,USDINR
INFOWAY_DEFAULT_METALS=XAUUSD,XAGUSD,XPTUSD,XPDUSD
INFOWAY_DEFAULT_ENERGY=USOIL,UKOIL,NATGAS

# ── Email (SMTP) ─────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@setupfx.com
SMTP_TLS=true

# ── SMS provider ─────────────────────────────────────────────────────────
SMS_PROVIDER=mock
SMS_API_KEY=
SMS_SENDER_ID=STPFX

# ── S3 (backups, screenshots) ────────────────────────────────────────────
S3_BUCKET=
S3_REGION=ap-south-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT_URL=

# ── Celery ───────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Observability ────────────────────────────────────────────────────────
SENTRY_DSN=
LOG_LEVEL=INFO
LOG_JSON=true

# ── Seed / Bootstrap ─────────────────────────────────────────────────────
SEED_SUPER_ADMIN_EMAIL=admin@setupfx.com
SEED_SUPER_ADMIN_PASSWORD=Admin@123
SEED_SUPER_ADMIN_MOBILE=9999999999
RUN_SEED_ON_STARTUP=true

# ── Trading ──────────────────────────────────────────────────────────────
DEFAULT_TIMEZONE=Asia/Kolkata
MARKET_OPEN_TIME=09:15
MARKET_CLOSE_TIME=15:30
MUHURAT_OPEN_TIME=18:15
MUHURAT_CLOSE_TIME=19:15
